# ============================================================
# Variables de Entorno - MotiChat (gRPC + Firebase)
# ============================================================
# DESARROLLO: Copia este archivo como .env y rellena los valores:
#   cp .env.example .env
#
# RENDER: Configura las variables directamente en el dashboard
#         de Render (Settings → Environment).
# ============================================================

# --- Servidor gRPC ---
GRPC_HOST=localhost
GRPC_PORT=50051

# --- Servidor Flask ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# --- Firebase Admin SDK ---
# DESARROLLO: Ruta al archivo JSON de credenciales del service account
FIREBASE_CREDENTIALS_PATH=server/firebase_config.json

# RENDER: Pegar el contenido COMPLETO del JSON como string
# (no usar en desarrollo local, solo en Render)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...","...":"..."}

# --- Firebase Web (para el frontend) ---
# Obtener desde: Firebase Console → Configuración → Tus apps → App web
FIREBASE_API_KEY=tu_api_key_aqui
FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456
